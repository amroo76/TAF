[mysqld]

# -- Connection / threading ------------------------------------------------
max_connections=200
open_files_limit=65535
table_open_cache=2048
thread_cache_size=128

# -- InnoDB (still needed for mysql.* system tables) -----------------------
innodb_buffer_pool_size=256M
innodb_log_file_size=128M
innodb_flush_method=O_DIRECT
innodb_file_per_table=1

# -- TidesDB plugin --------------------------------------------------------
plugin_maturity=experimental
plugin_dir=/usr/local/mariadb/lib/plugin
plugin_load_add=ha_tidesdb.so

# -- TidesDB global system variables (READONLY - set at startup) -----------
tidesdb_flush_threads=2
tidesdb_compaction_threads=2
tidesdb_block_cache_size=2147483648
tidesdb_max_open_sstables=256
tidesdb_log_level=NONE
